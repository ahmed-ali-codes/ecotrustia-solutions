# ============================================================
#  Ecotrustia Solutions — Environment Variables Template
# ============================================================
#  Copy this file to `.env.local` and fill in real values.
#  NEVER commit your actual .env or .env.local to git.
# ============================================================


# ── Admin Credentials ────────────────────────────────────────
# The username used to log into the /adminx admin panel.
ADMIN_USERNAME=your_admin_username_or_email

# bcrypt hash of your admin password, Base64-encoded.
# Generate with the setup script:  node scripts/hash-password.js
ADMIN_PASSWORD_HASH=your_bcrypt_password_hash_base64_encoded


# ── JWT Authentication ────────────────────────────────────────
# Must be a long, random, secret string (32+ characters).
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# ── Gemini Chatbot ────────────────────────────────────────────
# Get an API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here


# ── Vercel Blob Storage ───────────────────────────────────────
# Required for image uploads and JSON data storage in production.
# Create a Blob store in your Vercel dashboard → Storage → Blob.
# The token is auto-created; copy it from the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here
